# Copy this file to ../.env (project root) and fill in real values. Never commit .env.

# ESP32 device on the local network
ESP32_IP=192.168.1.50
ESP32_TIMEOUT_SECONDS=2

# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# Anthropic (Kirby persona)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Google Places API (New) for nearby clinic / hospital lookup.
# Enable "Places API (New)" in Google Cloud, then paste the key here.
GOOGLE_PLACES_API_KEY=

# Behaviour
POLLING_INTERVAL_MS=1000
ROLLING_WINDOW_SECONDS=300
ANOMALY_DEBOUNCE_SPO2_SECONDS=30
ANOMALY_DEBOUNCE_BPM_SECONDS=60
